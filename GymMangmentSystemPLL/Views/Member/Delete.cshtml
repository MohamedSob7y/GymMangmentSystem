
    <div class="container">
        <main role="main" class="pb-3">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card p-5 shadow text-center">
                            <h2>@ViewBag.MemberName</h2>
                            <p class="fs-3 text-primary-color mb-4">Are you sure you want to delete this member?</p>
                            <div class="alert alert-warning text-start" role="alert">
                                <strong>Warning!</strong> This action cannot be undone. All member data will be permanently deleted.
                            </div>
                            @* ممكن ابعت Id as Hidden Input *@
                            <form method="post" asp-action="DeleteConfirmed" asp-route-id="@ViewBag.MemberId" class="mt-4">
                                @* لازم الفورم تبعت الداتا دى لAction From Type Http Post *@
                                <div class="buttons d-flex justify-content-between gap-3">
                                    <a asp-controller="Member" asp-action="Index" class="btn-outline flex-fill">NO</a>
                                    <button type="submit" class="btn-fill flex-fill">Yes</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
@section Scripts {
    @* <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script> *@
    <partial name="_ValidationScriptsPartial">
}
