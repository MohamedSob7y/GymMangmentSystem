@using GymMangmentsystemBLL.View_Models.Member_View_Model
@model IEnumerable<MemberViewModel>
@* لازم بقا اعرف هنا فى view دى انها تستخدم الكود اللى موجود فى LayOutView in Shared  *@

@* دى حل لمشكلة Render For Script  *@
<div class="container">
    <main role="main" class="pb-3">
        <div id="Alert" class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>
            Member Created Successfully
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div id="Alert" class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Member Failed To Create
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <div class="container">
            <header class="d-flex justify-content-end mt-5 mb-4 align-items-center">
                <a href="\Member\Create" class="btn btn-fill fw-medium rounded-pill px-3 py-3">
                    + Add Member
                </a>
            </header>
            @if (Model.Any() && Model is not null)//it has Data  اعرضلى المعلومات ولو مفيش يبقى تعرض No Member Avialble
            {
                <div class="table-responsive " style="overflow: visible;">
                    <table class="table table-borderless">
                        <thead>
                            <tr>
                                @* يبقى Header بعمله بالطريقة دى عشان اضمن وتكون More Safty *@
                                @* عشان اضمن ان الاسم اللى موجود فى VM هو هو اللى Frontend كاتبها فى view  *@
                                <th><span>@nameof(MemberViewModel.Photo)</span></th>
                                <th><span>@nameof(MemberViewModel.Name)</span></th>
                                <th><span>@nameof(MemberViewModel.Email)</span></th>
                                <th><span>@nameof(MemberViewModel.Gender)</span></th>
                                <th><span>@nameof(MemberViewModel.Phone)</span></th>
                                <th><span>Action</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model)
                            {
                                <tr>
                                    @* عايز اتاكد ان كل Member has Photo ولا لاء ولو لاء احطله صورة default  *@
                                    <td>
                                        <span class="avatar">
                                            @if (string.IsNullOrEmpty(member.Photo))
                                            {
                                                //لو معندوش اى صورة اطبع الصورة الافتراضية دى انما لو عنده روح اطبع الصورة الاصليه بتاعته وخليها dynamic
                                                <img src="~/images/User.jpg" alt="Default Avatar" class="rounded-circle"
                                                     style="width: 40px; height: 40px;" />
                                            }
                                            else
                                            {
                                                <img src="~/images/@member.Photo" alt="Default Avatar" class="rounded-circle"
                                                     style="width: 40px; height: 40px;" />
                                            }
                                        </span>
                                    </td>
                                    <td><span>@member.Name</span></td>
                                    <td><span>@member.Email</span></td>
                                    <td><span>@member.Gender</span></td>
                                    <td><span>@member.Phone</span></td>
                                    <td class="action position-relative">
                                        <div class="dropdown">
                                            @* اظبط الDropDown for Specific Memebr *@
                                            <button class="btn btn-link p-0 border-0" type="button"
                                                    id="dropdownMenuButton-@member.Id" data-bs-toggle="dropdown"
                                                    aria-expanded="false">
                                                <img src="~/images/action dots.jpg" alt="action icon" />
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-start"
                                                aria-labelledby="dropdownMenuButton-@member.Id">
                                                <li>
                                                    <a href="\Member\MemberDetails\memberId"
                                                       class="dropdown-item d-flex align-items-center gap-3">
                                                        <img src="~/images/info 1.jpg" alt="info icon"
                                                             style="width: 20px; height: 20px;" />
                                                        <span>View Member Data</span>
                                                    </a>
                                                </li>
                                                <li>
                                                    <a href="\Member\HealthRecordDetails\memberId"
                                                       class="dropdown-item d-flex align-items-center gap-3">
                                                        <img src="~/images/info 1.jpg" alt="info icon"
                                                             style="width: 20px; height: 20px;" />
                                                        <span>View Health Record Data</span>
                                                    </a>
                                                </li>
                                                <li>
                                                    <hr class="dropdown-divider">
                                                </li>
                                                <li>
                                                    <a href="\Member\EditMember\memberId"
                                                       class="dropdown-item d-flex align-items-center gap-3">
                                                        <img src="~/images/edit.jpg" alt="edit icon"
                                                             style="width: 20px; height: 20px;" />
                                                        <span>Edit Member Data</span>
                                                    </a>
                                                </li>
                                                <li>
                                                    <hr class="dropdown-divider">
                                                </li>
                                                <li>
                                                    <a href="\Member\Delete\memberId"
                                                       class="dropdown-item d-flex align-items-center gap-3 text-danger">
                                                        <img src="~/images/x-circle 1.jpg" alt="delete icon"
                                                             style="width: 20px; height: 20px;" />
                                                        <span>Delete</span>
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-workspace display-1 text-muted"></i>
                    <h4 class="mt-3 text-muted">No Members Available</h4>
                    <p class="text-muted">Add your first Member to get started</p>
                </div>
            }
        </div>
    </main>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const alertBox = document.getElementById("Alert");
            if (alertBox) {
                setTimeout(() => {
                    alertBox.style.transition = "opacity 0.5s ease";
                    alertBox.style.opacity = "0";
                    setTimeout(() => alertBox.remove(), 500);
                }, 1500);
            }
        });
    </script>
}

